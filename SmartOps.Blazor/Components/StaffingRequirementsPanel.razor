@using SmartOps.Models

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">FTE Requirements</h5>
        <div class="d-flex align-items-center gap-2">
            <label class="form-label mb-0 small">Interval:</label>
            <select class="form-select form-select-sm" style="width: 100px;" @bind="IntervalMinutes" @bind:event="onchange">
                <option value="15">15 min</option>
                <option value="30">30 min</option>
                <option value="60">60 min</option>
            </select>
        </div>
    </div>
    <div class="card-body">
        @if (!SelectedWorkgroups.Any())
        {
            <div class="alert alert-info" role="alert">
                Please select one or more workgroups to view FTE requirements.
            </div>
        }
        else
        {
            <div class="row mb-3">
                <div class="col-12 d-flex justify-content-between align-items-center">
                    <button class="btn btn-primary btn-sm" @onclick="ShowAddRequirementModal">
                        + Add Requirement
                    </button>
                    <span class="text-muted small">
                        Showing requirements for: <strong>@string.Join(", ", SelectedWorkgroups)</strong>
                    </span>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-sm table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Workgroup</th>
                            <th>Day</th>
                            <th>Time</th>
                            <th>Required FTE</th>
                            <th>Expected Calls</th>
                            <th>Required Skills</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (requirements != null)
                        {
                            @foreach (var req in requirements.OrderBy(r => r.Division).ThenBy(r => r.DayOfWeek).ThenBy(r => r.HourOfDay))
                            {
                                <tr>
                                    <td>@req.Division</td>
                                    <td>@GetDayOfWeekName(req.DayOfWeek)</td>
                                    <td>@FormatTimeSlot(req.HourOfDay)</td>
                                    <td>
                                        <input type="number" step="0.25" min="0" class="form-control form-control-sm" 
                                            @bind="req.RequiredHeadCount" style="width: 80px;" />
                                    </td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm" 
                                            @bind="req.ExpectedCallVolume" style="width: 100px;" />
                                    </td>
                                    <td>@(req.RequiredSkills ?? "-")</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" @onclick="@(() => SaveRequirement(req))">
                                            Save
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="@(() => DeleteRequirement(req.Id))">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                <p class="text-muted small">
                    <i class="bi bi-info-circle"></i> FTE (Full Time Equivalent) represents a full-time person working for the selected interval.
                    1.0 FTE = one person for the full @IntervalMinutes minutes. Modify requirements and click Save.
                </p>
            </div>
        }
    </div>
</div>
