@using SmartOps.Models

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Team Management</h5>
        @if (SelectedWorkgroups.Any())
        {
            <div class="btn-group btn-group-sm" role="group">
                <button type="button"
                        class="btn @(activeSubTab == "members" ? "btn-primary" : "btn-outline-primary")"
                        @onclick='() => activeSubTab = "members"'>
                    Members
                </button>
                <button type="button"
                        class="btn @(activeSubTab == "timeoff" ? "btn-primary" : "btn-outline-primary")"
                        @onclick='() => activeSubTab = "timeoff"'>
                    Time Off
                    @if (PendingCount > 0)
                    {
                        <span class="badge bg-warning text-dark ms-1">@PendingCount</span>
                    }
                </button>
            </div>
        }
    </div>
    <div class="card-body">
        @if (!SelectedWorkgroups.Any())
        {
            <div class="alert alert-info" role="alert">
                Please select one or more workgroups to view team members.
            </div>
        }
        else if (activeSubTab == "members")
        {
            <!-- Members Tab -->
            <div class="row mb-3">
                <div class="col-md-6">
                    <input type="text" class="form-control" placeholder="Search by AD login..."
                           @bind="searchTerm" @bind:event="oninput" @bind:after="ApplyFilters" />
                </div>
            </div>

            @foreach (var group in SelectedWorkgroups)
            {
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0">@group.Name
                            <span class="badge bg-secondary ms-1">@group.Members.Count members</span>
                        </h6>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenAddForm(group.Id)">
                            + Add Member
                        </button>
                    </div>

                    @if (showAddForm && addToWorkGroupId == group.Id)
                    {
                        <div class="card card-body mb-2 bg-light">
                            <div class="row g-2 align-items-end">
                                <div class="col-md-6">
                                    <label class="form-label">AD Login Name</label>
                                    <input type="text" class="form-control form-control-sm"
                                           placeholder="e.g. jdoe" @bind="newMemberLogin" />
                                </div>
                                <div class="col-md-auto">
                                    <button class="btn btn-sm btn-primary" @onclick="SubmitAddMember">Add</button>
                                    <button class="btn btn-sm btn-secondary ms-1" @onclick="CancelAddForm">Cancel</button>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(addError))
                            {
                                <div class="text-danger small mt-1">@addError</div>
                            }
                        </div>
                    }

                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>AD Login</th>
                                    <th>Added</th>
                                    <th>Added By</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var groupMembers = filteredMembers
                                        .Where(x => x.Group.Id == group.Id)
                                        .Select(x => x.Member)
                                        .ToList();
                                }
                                @if (groupMembers.Any())
                                {
                                    @foreach (var member in groupMembers)
                                    {
                                        <tr>
                                            <td>@member.AdloginName</td>
                                            <td>@member.AddedDateUtc.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                            <td>@member.AddedBy</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => RemoveMember(group.Id, member.AdloginName)">
                                                    Remove
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-muted text-center py-3">
                                            @(string.IsNullOrWhiteSpace(searchTerm) ? "No members in this workgroup." : "No members match the search.")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
        else
        {
            <!-- Time Off Tab -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" id="showReviewedCheck"
                           @bind="showReviewedRequests" @bind:after="ApplyTimeOffFilters" />
                    <label class="form-check-label" for="showReviewedCheck">Show reviewed requests</label>
                </div>
            </div>

            @if (!filteredTimeOffRequests.Any())
            {
                <div class="alert alert-info">
                    No @(showReviewedRequests ? "" : "pending ")time-off requests for this team.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Employee</th>
                                <th>Dates / Hours</th>
                                <th>Reason</th>
                                <th>Requested</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in filteredTimeOffRequests)
                            {
                                <tr>
                                    <td>@req.AdloginName</td>
                                    <td class="text-nowrap">
                                        @FormatDateRange(req.StartDate, req.EndDate)
                                        @if (req.IsPartialShift && req.PartialStart.HasValue && req.PartialEnd.HasValue)
                                        {
                                            <br /><small class="text-muted">@req.PartialStart.Value.ToString("HH:mm") – @req.PartialEnd.Value.ToString("HH:mm")</small>
                                        }
                                        @if (req.PlanToMakeUpTime && req.MakeUpStart.HasValue && req.MakeUpEnd.HasValue)
                                        {
                                            <br /><small class="text-success">Make up: @req.MakeUpStart.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt") – @req.MakeUpEnd.Value.ToLocalTime().ToString("h:mm tt")</small>
                                        }
                                    </td>
                                    <td>@req.Reason</td>
                                    <td class="text-nowrap">@req.RequestedOn.ToLocalTime().ToString("MMM d, yyyy")</td>
                                    <td><span class="badge @GetStatusBadgeClass(req.Status)">@req.Status</span></td>
                                    <td class="text-nowrap">
                                        @if (req.Status == TimeOffStatus.Pending)
                                        {
                                            @if (reviewingRequestId != req.TimeOffRequestId)
                                            {
                                                <button class="btn btn-sm btn-success me-1"
                                                        @onclick="() => BeginReview(req.TimeOffRequestId, true)">
                                                    Approve
                                                </button>
                                                <button class="btn btn-sm btn-danger"
                                                        @onclick="() => BeginReview(req.TimeOffRequestId, false)">
                                                    Deny
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">@(reviewingApprove ? "Approving..." : "Denying...")</span>
                                            }
                                        }
                                        else
                                        {
                                            <small class="text-muted">
                                                @req.ReviewedBy<br />@req.ReviewedOn?.ToLocalTime().ToString("MMM d, yyyy")
                                            </small>
                                        }
                                    </td>
                                </tr>
                                @if (reviewingRequestId == req.TimeOffRequestId)
                                {
                                    <tr class="table-@(reviewingApprove ? "success" : "danger") bg-opacity-10">
                                        <td colspan="6" class="py-2 px-3">
                                            <div class="d-flex gap-2 align-items-start flex-wrap">
                                                <div class="flex-grow-1" style="min-width: 220px; max-width: 420px;">
                                                    <label class="form-label mb-1 small">
                                                        Notes (optional)
                                                    </label>
                                                    <textarea class="form-control form-control-sm" rows="2"
                                                              placeholder="Add a note for the employee..."
                                                              @bind="reviewNotes"></textarea>
                                                    @if (!string.IsNullOrEmpty(reviewError))
                                                    {
                                                        <div class="text-danger small mt-1">@reviewError</div>
                                                    }
                                                </div>
                                                <div class="d-flex gap-1 align-items-end pb-1">
                                                    <button class="btn btn-sm @(reviewingApprove ? "btn-success" : "btn-danger")"
                                                            @onclick="SubmitReview">
                                                        @(reviewingApprove ? "Confirm Approve" : "Confirm Deny")
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-secondary"
                                                            @onclick="CancelReview">
                                                        Cancel
                                                    </button>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    </div>
</div>
