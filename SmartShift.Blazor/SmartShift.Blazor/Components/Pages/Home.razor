@page "/"
@using SmartShift.Blazor.Services
@using Microsoft.AspNetCore.Authorization
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@pageTitle</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (context.User.IsInRole("Supervisor") || context.User.IsInRole("Admin"))
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                <strong>Welcome, @context.User.Identity?.Name!</strong>
                <p>Redirecting to Workforce Management Dashboard...</p>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        else
        {
            <div class="container py-5">
                <div class="row mb-4">
                    <div class="col-12">
                        <h1>Welcome to TimeKeeper, @context.User.Identity?.Name</h1>
                        <p class="lead text-muted">Manage your work schedule and time off requests</p>
                    </div>
                </div>

                @if (nextShift != null)
                {
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="card border-primary">
                                <div class="card-body">
                                    <h5 class="card-title">? Next Shift</h5>
                                    <h6 class="card-subtitle mb-2">@nextShift.Division</h6>
                                    <p class="mb-1"><strong>@nextShift.StartTime.ToString("dddd, MMMM dd")</strong></p>
                                    <p class="mb-3"><strong>@nextShift.StartTime.ToString("HH:mm")</strong> - <strong>@nextShift.EndTime.ToString("HH:mm")</strong></p>
                                    <small class="text-muted">
                                        @{
                                            var hoursUntil = (nextShift.StartTime - DateTime.Now).TotalHours;
                                            if (hoursUntil > 24)
                                            {
                                                <span>In @Math.Floor((nextShift.StartTime - DateTime.Now).TotalDays) day(s)</span>
                                            }
                                            else if (hoursUntil > 0)
                                            {
                                                <span>In @Math.Floor(hoursUntil) hour(s)</span>
                                            }
                                            else
                                            {
                                                <span>Today</span>
                                            }
                                        }
                                    </small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title">?? This Week</h5>
                                    <h3 class="mb-1">@weeklyHours.ToString("F1")</h3>
                                    <p class="text-muted">hours scheduled</p>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="row">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">?? My Schedule</h5>
                                <p class="card-text">View and manage your work schedule, shifts, and breaks.</p>
                                <a href="schedule" class="btn btn-primary">View Schedule</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">?? Skills & Certifications</h5>
                                <p class="card-text">View your skills and track your certifications.</p>
                                <a href="skills" class="btn btn-primary">View Skills</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="card shadow-lg">
                        <div class="card-body">
                            <h1 class="card-title text-center mb-4">TimeKeeper</h1>
                            <p class="card-text text-center text-muted mb-4">Workforce Management & Scheduling System</p>
                            <div class="d-grid gap-2">
                                <a href="Account/Login" class="btn btn-primary btn-lg">Login</a>
                                <a href="Account/Register" class="btn btn-outline-primary btn-lg">Register</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>


@using SmartOps.Models

