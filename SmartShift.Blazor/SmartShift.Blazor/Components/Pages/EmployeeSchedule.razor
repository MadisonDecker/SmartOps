@page "/"
@page "/schedule"
@using SmartOps.Models
@using SmartShift.Blazor.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">Schedule for @employeeDisplayName</h1>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Next Shift</h5>
                    @if (nextShift != null)
                    {
                        <p class="mb-1">@nextShift.StartTime.ToString("HH:mm") – @nextShift.EndTime.ToString("HH:mm")</p>
                        <p class="text-muted">@((nextShift.StartTime - DateTime.Now).TotalHours > 0 ? $"In {Math.Floor((nextShift.StartTime - DateTime.Now).TotalHours)} hours" : "Today")</p>
                    }
                    else
                    {
                        <p class="text-muted">No upcoming shifts</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">This Week Hours</h5>
                    <h3>@weeklyHours.ToString("F1")</h3>
                    <p class="text-muted">hours scheduled</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Weekly Schedule</h5>
                        <div>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="PreviousWeek">← Previous</button>
                            <span class="mx-2">Week of @weekStart.ToString("MMM dd")</span>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="NextWeek">Next →</button>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    @{
                        var approvedTimeOff = GetApprovedTimeOffInWeek();
                        var makeUpTime      = GetMakeUpTimeInWeek();
                        var hasContent      = (shifts != null && shifts.Any()) || approvedTimeOff.Any() || makeUpTime.Any();
                    }
                    @if (hasContent)
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Client</th>
                                        <th>Start Time</th>
                                        <th>End Time</th>
                                        <th>Duration</th>
                                        <th>Status</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (shifts != null)
                                    {
                                        @foreach (var shift in shifts.OrderBy(s => s.StartTime))
                                        {
                                            <tr>
                                                <td>@shift.StartTime.ToString("ddd, MMM dd")</td>
                                                <td>@(shift.ClientName ?? "-")</td>
                                                <td>@shift.StartTime.ToString("HH:mm")</td>
                                                <td>@shift.EndTime.ToString("HH:mm")</td>
                                                <td>@Math.Round((shift.EndTime - shift.StartTime).TotalHours, 2) hrs</td>
                                                <td>
                                                    <span class="badge @GetStatusBadgeClass(shift.Status)">
                                                        @shift.Status
                                                    </span>
                                                </td>
                                                <td>
                                                    @{
                                                        var tor = GetAnyRequest(shift);
                                                    }
                                                    @if (tor != null)
                                                    {
                                                        var (badgeClass, label) = tor.Status switch
                                                        {
                                                            TimeOffStatus.Approved => ("bg-success", "Approved"),
                                                            TimeOffStatus.Denied   => ("bg-danger",  "Denied"),
                                                            _                      => ("bg-warning text-dark", "Pending")
                                                        };
                                                        <span class="badge @badgeClass" title="@tor.ReviewNotes">@label</span>
                                                        @if (tor.Status == TimeOffStatus.Denied && !string.IsNullOrEmpty(tor.ReviewNotes))
                                                        {
                                                            <br /><small class="text-muted">@tor.ReviewNotes</small>
                                                        }
                                                    }
                                                    else if (CanRequestTimeOff(shift))
                                                    {
                                                        <button class="btn btn-sm btn-outline-warning"
                                                                @onclick="() => OpenTimeOffModal(shift)">
                                                            Request Time Off
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                            @if (shift.Breaks.Any())
                                            {
                                                <tr class="table-light">
                                                    <td colspan="7">
                                                        <small class="text-muted">
                                                            <strong>Breaks:</strong>
                                                            @foreach (var breakItem in shift.Breaks)
                                                            {
                                                                <span class="badge bg-info me-2">
                                                                    @breakItem.BreakType @breakItem.StartTime.ToString("HH:mm")-@breakItem.EndTime.ToString("HH:mm")
                                                                    @if (breakItem.IsTaken)
                                                                    {
                                                                        <span>✓</span>
                                                                    }
                                                                </span>
                                                            }
                                                        </small>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    }
                                    @* Approved time-off rows — shown for dates where the shift was
                                       suppressed by a ScheduleException so the employee can see the approval. *@
                                    @for (int dayOffset = 0; dayOffset < 7; dayOffset++)
                                    {
                                        var date   = DateOnly.FromDateTime(weekStart.AddDays(dayOffset));
                                        var appTor = approvedTimeOff.FirstOrDefault(r =>
                                            r.StartDate <= date && r.EndDate >= date);
                                        @if (appTor != null)
                                        {
                                            <tr class="table-success">
                                                <td>@date.ToString("ddd, MMM dd")</td>
                                                <td>—</td>
                                                <td colspan="2">
                                                    <small class="fst-italic text-muted">
                                                        @(appTor.IsPartialShift ? "Partial Time Off" : "Time Off")
                                                        @if (!string.IsNullOrEmpty(appTor.Reason))
                                                        {
                                                            <text> — @appTor.Reason</text>
                                                        }
                                                    </small>
                                                </td>
                                                <td>—</td>
                                                <td><span class="badge bg-success">Approved</span></td>
                                                <td>
                                                    <small class="text-muted">
                                                        @appTor.ReviewedBy<br />@appTor.ReviewedOn?.ToLocalTime().ToString("MMM d, yyyy")
                                                    </small>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    @* Make-up time rows — temporary additions committed by the employee.
                                       Not a ScheduleException; surfaced directly from the TimeOffRequest. *@
                                    @foreach (var mu in makeUpTime)
                                    {
                                        var muStart = mu.MakeUpStart!.Value.ToLocalTime();
                                        var muEnd   = mu.MakeUpEnd!.Value.ToLocalTime();
                                        <tr class="table-info">
                                            <td>@muStart.ToString("ddd, MMM dd")</td>
                                            <td>—</td>
                                            <td>@muStart.ToString("HH:mm")</td>
                                            <td>@muEnd.ToString("HH:mm")</td>
                                            <td>@Math.Round((muEnd - muStart).TotalHours, 2) hrs</td>
                                            <td><span class="badge bg-info text-dark">Make-Up Time</span></td>
                                            <td><small class="text-muted">For: @mu.StartDate.ToString("MMM d")</small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4">No shifts scheduled for this week</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (showTimeOffModal && selectedShift != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Request Time Off</h5>
                    <button type="button" class="btn-close" @onclick="CloseTimeOffModal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-3">
                        <strong>Shift:</strong> @selectedShift.StartTime.ToString("dddd, MMMM dd yyyy")<br />
                        <strong>Time:</strong> @selectedShift.StartTime.ToString("HH:mm") – @selectedShift.EndTime.ToString("HH:mm")
                    </p>

                    <div class="mb-3">
                        <label class="form-label">Reason <span class="text-danger">*</span></label>
                        <textarea class="form-control" rows="3" placeholder="Briefly describe your reason for the request"
                                  @bind="timeOffReason"></textarea>
                    </div>

                    <!-- Partial shift -->
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="partialShiftCheck"
                                   @bind="_isPartialShift" />
                            <label class="form-check-label" for="partialShiftCheck">Partial shift request</label>
                        </div>
                        @if (_isPartialShift)
                        {
                            <div class="row g-2 mt-1">
                                <div class="col-6">
                                    <label class="form-label mb-1">From</label>
                                    <select class="form-select form-select-sm"
                                            @bind="_partialStart"
                                            @bind:after="OnPartialStartChanged">
                                        @foreach (var slot in GetPartialStartSlots())
                                        {
                                            <option value="@slot">@FormatTimeSlot(slot)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label mb-1">To</label>
                                    <select class="form-select form-select-sm" @bind="_partialEnd">
                                        @foreach (var slot in GetPartialEndSlots())
                                        {
                                            <option value="@slot">@FormatTimeSlot(slot)</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="form-text">Times are limited to your scheduled shift (@FormatTimeSlot(SnapToHalfHour(selectedShift!.StartTime).ToString("HH:mm")) – @FormatTimeSlot(SnapToHalfHour(selectedShift!.EndTime).ToString("HH:mm"))).</div>
                        }
                    </div>

                    <!-- Make-up time -->
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="makeUpTimeCheck"
                                   @bind="_planToMakeUpTime" />
                            <label class="form-check-label" for="makeUpTimeCheck">Plan to make up time</label>
                        </div>
                        @if (_planToMakeUpTime)
                        {
                            <div class="row g-2 mt-1">
                                <div class="col-12 col-sm-5">
                                    <label class="form-label mb-1">Date</label>
                                    <input type="date" class="form-control form-control-sm"
                                           @bind="_makeUpDate" />
                                </div>
                                <div class="col-6 col-sm-3">
                                    <label class="form-label mb-1">From</label>
                                    <select class="form-select form-select-sm"
                                            @bind="_makeUpStartTime"
                                            @bind:after="OnMakeUpStartTimeChanged">
                                        @foreach (var slot in GetAllHalfHourSlots())
                                        {
                                            <option value="@slot">@FormatTimeSlot(slot)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-6 col-sm-4">
                                    <label class="form-label mb-1">To</label>
                                    <select class="form-select form-select-sm" @bind="_makeUpEndTime">
                                        @foreach (var slot in GetMakeUpEndSlots())
                                        {
                                            <option value="@slot">@FormatTimeSlot(slot)</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="form-text">You will be notified if this conflicts with a scheduled shift.</div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(timeOffError))
                    {
                        <div class="alert alert-danger py-2">@timeOffError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseTimeOffModal">Cancel</button>
                    <button type="button" class="btn btn-warning" @onclick="async () => await SubmitTimeOffRequest()">Submit Request</button>
                </div>
            </div>
        </div>
    </div>
}

