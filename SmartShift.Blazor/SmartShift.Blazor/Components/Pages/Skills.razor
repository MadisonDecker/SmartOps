@page "/skills"
@using SmartOps.Models
@using SmartShift.Blazor.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">My Skills & Certifications</h1>
        </div>
    </div>

    @if (employee != null)
    {
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Employee Information</h5>
                        <p class="mb-1"><strong>Division:</strong> @employee.Division</p>
                        <p class="mb-1"><strong>Supervisor:</strong> @employee.SupervisorName</p>
                        <p class="mb-1"><strong>Start Date:</strong> @employee.StartDate.ToString("MMM dd, yyyy")</p>
                        <p class="mb-1"><strong>Phone:</strong> @employee.PhoneNumber</p>
                        <p class="mb-0"><strong>Status:</strong> 
                            <span class="badge @(employee.IsActive ? "bg-success" : "bg-danger")">
                                @(employee.IsActive ? "Active" : "Inactive")
                            </span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Skills & Certifications</h5>
                        <button class="btn btn-sm btn-primary">+ Add Skill</button>
                    </div>
                </div>
                <div class="card-body">
                    @if (skills != null && skills.Any())
                    {
                        <div class="row">
                            @foreach (var skill in skills)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="card border-light">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <div>
                                                    <h6 class="card-title">@skill.SkillName</h6>
                                                    <small class="text-muted">@skill.SkillCode</small>
                                                </div>
                                                <span class="badge @GetProficiencyBadgeClass(skill.ProficiencyLevel)">
                                                    @skill.ProficiencyLevel
                                                </span>
                                            </div>
                                            <p class="mb-2">
                                                <small class="text-muted">
                                                    <strong>Effective:</strong> @skill.EffectiveDate.ToString("MMM dd, yyyy")<br />
                                                    @if (skill.ExpirationDate.HasValue)
                                                    {
                                                        <strong>Expires:</strong> @skill.ExpirationDate.Value.ToString("MMM dd, yyyy")<br />
                                                    }
                                                    <strong>Status:</strong> <span class="badge @(skill.IsActive ? "bg-success" : "bg-warning")">@(skill.IsActive ? "Active" : "Inactive")</span>
                                                </small>
                                            </p>
                                            @if (!string.IsNullOrEmpty(skill.Notes))
                                            {
                                                <p class="mb-0"><small>@skill.Notes</small></p>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4">No skills added yet</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

